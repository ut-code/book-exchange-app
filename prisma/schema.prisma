// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // NOTE: When using postgresql, mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
  url      = env("DATABASE_URL")
}

model Example {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Necessary for Next auth
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? // @db.Text
  access_token      String? // @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? // @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                       String              @id @default(cuid())
  name                     String?
  email                    String?             @unique
  emailVerified            DateTime?
  image                    String?
  profile                  String?
  accounts                 Account[]
  sessions                 Session[]
  books                    UserBooks[]
  requesterExchangeRequest ExchangeRequest[]   @relation("requesterExchangeRequest")
  addresseeExchangeRequest ExchangeRequest[]   @relation("addresseeExchangeRequest")
  requesterFriendRequest   FriendshipRequest[] @relation("requesterFriendRequest")
  addresseFriendRequest    FriendshipRequest[] @relation("addresseFriendRequest")
  RoomMembers              RoomMembers[]
  PrivateMessage           PrivateMessage[]
  PublicMessage            PublicMessage[]
  BookFav                  BookFav[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model GoogleAPIDatabaseBook {
  id             String    @id @default(cuid())
  title          String
  authors        String[]
  translators    String[]
  description    String?
  previewLink    String?
  infoLink       String?
  publisher      String?
  publishedDate  DateTime?
  ISBN_13        String?
  language       String?
  pageCount      Int?
  categories     String[]
  country        String?
  isEbook        Boolean?
  listPrice      Int?
  currencyCode   String?
  smallThumbnail String?
  thumbnail      String?
  publicDomain   Boolean?
  apiSelfLink    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  Book           Book[]
}

model Book {
  id                       String                 @id @default(cuid())
  bookDatabase_id          String?
  bookDatabaseType         String?
  title                    String
  authors                  String[]
  translators              String[]
  description              String?
  previewLink              String?
  infoLink                 String?
  publisher                String?
  publishedDate            DateTime?
  ISBN_13                  String?
  language                 String?
  pageCount                Int?
  categories               String[]
  country                  String?
  isEbook                  Boolean?
  listPrice                Int?
  currencyCode             String?
  smallThumbnail           String?
  thumbnail                String?
  publicDomain             Boolean?
  apiSelfLink              String?
  apiType                  String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  bookDatabase             GoogleAPIDatabaseBook? @relation(fields: [bookDatabase_id], references: [id])
  users                    UserBooks[]
  requesterExchangeRequest ExchangeRequest[]      @relation("requesterBooks")
  addresseeExchangeRequest ExchangeRequest[]      @relation("addresseeBooks")
  BookFav                  BookFav[]
}

model UserBooks {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model BookFav {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model ExchangeRequest {
  id                String   @id @default(cuid())
  requester_userId  String
  addressee_userId  String
  requester_bookIds String[]
  addressee_bookIds String[]
  status            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  requester         User     @relation(name: "requesterExchangeRequest", fields: [requester_userId], references: [id], onDelete: Cascade)
  addressee         User     @relation(name: "addresseeExchangeRequest", fields: [addressee_userId], references: [id], onDelete: Cascade)
  requester_books   Book[]   @relation("requesterBooks")
  addressee_books   Book[]   @relation("addresseeBooks")
}

model FriendshipRequest {
  id               String   @id @default(cuid())
  requester_userId String
  addressee_userId String
  status           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  requester        User     @relation(name: "requesterFriendRequest", fields: [requester_userId], references: [id], onDelete: Cascade)
  addressee        User     @relation(name: "addresseFriendRequest", fields: [addressee_userId], references: [id], onDelete: Cascade)
}

model Room {
  id             String           @id @default(cuid())
  name           String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  RoomMembers    RoomMembers[]
  PrivateMessage PrivateMessage[]
}

model RoomMembers {
  id          String   @id @default(cuid())
  roomId      String
  userId      String
  joined_date DateTime @default(now())
  left_date   DateTime
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrivateMessage {
  id          String   @id @default(cuid())
  senderId    String
  roomId      String
  message     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  is_modified Boolean  @default(false)
  is_deleted  Boolean  @default(false)
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender      User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model PublicMessage {
  id          String   @id @default(cuid())
  senderId    String
  message     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  is_modified Boolean  @default(false)
  is_deleted  Boolean  @default(false)
  sender      User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}
